{
  "manifest_version": 3,
  "name": "SIGSS+",
  "version": "1.0.0",
  "description": "Camada de produtividade inteligente sobre o SIGSS para servidores das UBSs de Betim.",
  "author": "Guilherme Paicheco Ferreira",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "http://sigss.betim.mg.gov.br/sigss/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "http://sigss.betim.mg.gov.br/sigss/*",
        "file:///*/mock_sigss.html",
        "file:///*/mock_sigss_launch.html"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}

